{
  "name": "defi-advisor",
  "version": "1.0.0",
  "description": "AI 驱动的加密市场智能投顾，整合技术分析、市场情绪和链上数据",
  "author": "宝哥 (Sebo) - @sebo_luo",
  "repository": "https://github.com/SeboLuo/defi-synthesis-hackathon",
